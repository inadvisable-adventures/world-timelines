{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "strict": true,
    "lib": ["ES2022", "WebWorker"],
    "outDir": "./public",
    "rootDir": "./src",
    "declaration": false,
    "sourceMap": true,
    "noEmitOnError": true
  },
  "include": ["src/worker/**/*.ts", "src/types/**/*.ts"]
}
